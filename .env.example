# ──────────────────────────────────────────────────────
# Saramin AI MCP — 환경변수 템플릿
# 이 파일을 복사해서 .env 로 저장하고 값을 채우세요.
# .env 파일은 절대 git에 커밋하지 마세요.
# ──────────────────────────────────────────────────────

# ── Jira (Atlassian) ──────────────────────────────────
JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your_atlassian_api_token_here
# 토큰 발급: https://id.atlassian.com/manage-profile/security/api-tokens

# ── Figma ─────────────────────────────────────────────
FIGMA_ACCESS_TOKEN=your_figma_personal_access_token_here
# 토큰 발급: Figma → 계정 설정 → Security → Personal access tokens

# ── Google Workspace / Drive / Sheets ────────────────
# GCP OAuth 클라이언트 시크릿 JSON 파일 경로 (gcp-oauth.keys.json)
GOOGLE_OAUTH_PATH=./credentials/gcp-oauth.keys.json
# Google OAuth 인증 후 자동 생성되는 토큰 파일 경로
GOOGLE_TOKEN_PATH=./credentials/google-token.json

# ── Axure HTML Export ─────────────────────────────────
# Axure 기획서가 저장된 기본 디렉터리
AXURE_DEFAULT_DIR=./reports
# 마지막 사용 경로 캐시 파일 (자동 생성)
AXURE_LAST_USED=./axure-last-used.json

# ── Zscaler / 기업 SSL 인증서 (선택) ─────────────────
# 기업 내부망에서 SSL 오류 발생 시 Zscaler 루트 인증서 경로 지정
# 발급 방법: docs/zscaler-setup.md 참고
# NODE_EXTRA_CA_CERTS=./certs/zscaler-root-ca.pem
